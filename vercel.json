{
  "buildCommand": "npm run install:all && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm run install:all",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:4000/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}